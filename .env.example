# Client (Vite) — optional: set when using `npm run dev` without `vercel dev`,
# to point the browser at a Vercel preview/deployment that serves `/api/*`.
# VITE_REVIEWS_API_BASE=https://your-deployment.vercel.app

# Google Places (server) — see README
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACE_ID=

# Contact form (server only — do not prefix with VITE_)
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=info@immortalathletics.co.uk
# CONTACT_FROM_EMAIL=Immortal Athletics <enquiries@yourdomain.com>
# CONTACT_ALLOWED_ORIGINS=https://immortalathletics.co.uk,https://www.immortalathletics.co.uk
